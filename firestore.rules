rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return getUserRole() in ['admin', 'executive'];
    }
    function isSafetyManager() {
      return getUserRole() in ['admin', 'executive', 'safety_manager'];
    }
    function getUserSiteId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.siteId;
    }
    function isSameSite(docSiteId) {
      return isAdmin() || getUserSiteId() == docSiteId;
    }
    function isValidTimestamp(field) {
      return request.resource.data[field] is string;
    }

    // ─── Users Collection ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── FCM Tokens ───────────────────────────────────────────────────────────
    match /fcm_tokens/{tokenId} {
      allow read: if isSignedIn() && (isOwner(tokenId) || isAdmin());
      allow write: if isSignedIn() && isOwner(tokenId);
    }

    // ─── Incidents ────────────────────────────────────────────────────────────
    match /incidents/{incidentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTimestamp('createdAt');
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── CAPAs (Corrective & Preventive Actions) ─────────────────────────────
    match /capas/{capaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Permits to Work ──────────────────────────────────────────────────────
    match /permits/{permitId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Hazards ──────────────────────────────────────────────────────────────
    match /hazards/{hazardId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── BBS Observations ─────────────────────────────────────────────────────
    match /observations/{obsId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Risk Assessments (HIRA) ──────────────────────────────────────────────
    match /risk_assessments/{raId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isSafetyManager();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Dynamic Risk Assessments ─────────────────────────────────────────────
    match /dynamic_risk_assessments/{draId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Bow-Tie Analysis ─────────────────────────────────────────────────────
    match /bowtie_analyses/{btId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isSafetyManager();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Training Records ─────────────────────────────────────────────────────
    match /training_records/{trId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Employee Profiles ────────────────────────────────────────────────────
    match /employees/{empId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isSafetyManager();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── PPE Compliance ───────────────────────────────────────────────────────
    match /ppe_records/{ppeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Occupational Health — Medical Surveillance ───────────────────────────
    match /medical_surveillance/{msId} {
      // Only safety managers / admin — POPIA-sensitive medical data
      allow read: if isSignedIn() && isSafetyManager();
      allow create: if isSignedIn() && isSafetyManager();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Occupational Health — First Aid Log ──────────────────────────────────
    match /first_aid_log/{faId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Workers' Compensation / COIDA ────────────────────────────────────────
    match /coida_claims/{claimId} {
      allow read: if isSignedIn() && isSafetyManager();
      allow create: if isSignedIn() && isSafetyManager();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Environment ──────────────────────────────────────────────────────────
    match /environmental_records/{envId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    match /waste_records/{wasteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    match /spill_records/{spillId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Compliance / Legal Documents ─────────────────────────────────────────
    match /compliance_docs/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isSafetyManager();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Equipment Management ─────────────────────────────────────────────────
    match /equipment/{eqId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    match /equipment_inspections/{insId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Contractor Management ────────────────────────────────────────────────
    match /contractors/{contractorId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isSafetyManager();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Action Items / Tracker ───────────────────────────────────────────────
    match /action_items/{actionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Emergency Broadcasts ─────────────────────────────────────────────────
    match /emergency_broadcasts/{broadcastId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Emergency Plans ──────────────────────────────────────────────────────
    match /emergency_plans/{planId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isSafetyManager();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── Muster Records ───────────────────────────────────────────────────────
    match /muster_records/{musterId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isSafetyManager();
      allow delete: if isAdmin();
    }

    // ─── AI Chat History ──────────────────────────────────────────────────────
    match /ai_chats/{chatId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isOwner(resource.data.userId);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // ─── Offline Sync Queue ───────────────────────────────────────────────────
    match /offline_queue/{queueId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow write: if isSignedIn();
    }

    // ─── Audit Logs (write-only for clients, read for admins) ─────────────────
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false; // Audit logs are immutable
    }

    // ─── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isOwner(resource.data.userId);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // ─── POPIA Consent Records ────────────────────────────────────────────────
    match /popia_consent/{consentId} {
      allow read: if isSignedIn() && (isOwner(consentId) || isAdmin());
      allow create: if isSignedIn() && isOwner(consentId);
      allow update: if isSignedIn() && isOwner(consentId);
      allow delete: if false; // Consent records are immutable for compliance
    }

    // ─── Sites ────────────────────────────────────────────────────────────────
    match /sites/{siteId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Catch-all deny ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
