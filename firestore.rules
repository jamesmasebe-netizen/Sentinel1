      // Allow any authenticated user to update status (e.g. investigators)
      allow update: if isAuthenticated() && 
                    isValidIncident(request.resource.data) &&
                    request.resource.data.reporterId == resource.data.reporterId && // Immutable
                    request.resource.data.createdAt == resource.data.createdAt; // Immutable
