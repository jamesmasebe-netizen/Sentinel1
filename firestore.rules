      allow update: if isAuthenticated() && 
                    isValidBowTieAnalysis(request.resource.data) &&
                    request.resource.data.authorId == resource.data.authorId &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    match /strategic_risks/{riskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    isValidStrategicRisk(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && 
                    isValidStrategicRisk(request.resource.data) &&
                    request.resource.data.authorId == resource.data.authorId &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    match /coida_claims/{claimId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    isValidCoidaClaim(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && 
                    isValidCoidaClaim(request.resource.data) &&
                    request.resource.data.authorId == resource.data.authorId &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    match /esg_metrics/{metricId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    isValidEsgMetric(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && 
                    isValidEsgMetric(request.resource.data) &&
                    request.resource.data.authorId == resource.data.authorId &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    isValidEmployee(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && 
                    isValidEmployee(request.resource.data) &&
                    request.resource.data.authorId == resource.data.authorId &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    match /employees/{employeeId}/authorizations/{authId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    isValidEmployeeAuthorization(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && 
                    isValidEmployeeAuthorization(request.resource.data) &&
                    request.resource.data.authorId == resource.data.authorId &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    match /employees/{employeeId}/ppe/{ppeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    isValidEmployeePPE(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && 
                    isValidEmployeePPE(request.resource.data) &&
                    request.resource.data.authorId == resource.data.authorId &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    match /action_items/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidActionItem(request.resource.data);
      allow update: if isAuthenticated() && isValidActionItem(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /risk_signoffs/{signOffId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    isValidRiskSignOff(request.resource.data) && 
                    request.resource.data.userId == request.auth.uid;
      allow update: if false; // Sign-offs are immutable
      allow delete: if false; // Sign-offs are immutable
    }

    match /dynamic_risk_assessments/{draId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    isValidDRA(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid;
      allow update: if false; // DRAs are immutable
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated(); // Allow system to create notifications
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
