                    request.resource.data.performedById == request.auth.uid;
      allow update: if isAuthenticated() && 
                    isValidMaintenanceLog(request.resource.data) &&
                    request.resource.data.performedById == resource.data.performedById && // Immutable
                    request.resource.data.date == resource.data.date && // Immutable
                    request.auth.uid == resource.data.performedById;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.performedById;
    }

    match /incidents/{incidentId} {
      allow read: if isAuthenticated();
